# Copy this file to .env and fill in the values
# Slack Incoming Webhook URL (required)
SLACK_WEBHOOK_URL=

# Bolna API configuration (optional, but required if Bolna webhooks do not include transcript)
# Base URL for Bolna API (example: https://api.bolna.example)
BOLNA_API_URL=

# API key or token for Bolna (used as Bearer token)
BOLNA_API_KEY=

# Port the Express server should listen on (optional, default 3000)
PORT=3000
